// ERP 8Q v2 — FASE L + M1 TN-first ecommerce + M4 unit grain
// M1: tn_orders entidad principal ecommerce; erp_orders = manual/interno/legacy
// M4: tn_order_item_units (1 prenda = 1 fila) — ver docs/erp-m4-tn-item-units-adr.md
// Ver docs/erp-m0-tn-first-adr.md

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

/// Estado del pipeline ERP (remito / allocation)
enum ErpProcessingStatus {
  pending_import
  imported
  manual_no_tn
  failed
}

/// Alineación TN panel/API ↔ remito ERP (auditoría histórica — no KPI negocio M1+)
enum TnErpReconciliationStatus {
  aligned
  tn_only_pending_erp
  erp_only_not_in_panel
  mismatch_amount
  unknown
}

/// Canal de la orden TN (M1 — ecommerce default)
enum TnOrderChannel {
  ecommerce
}

/// Estado comercial persistido — derivado de TN, no de erp_orders.estado
enum TnCommercialStatus {
  activo
  cancelado
  reembolsado
  pendiente
}

/// Estado de una corrida del pipeline live M5.4
enum PipelineRunStatus {
  running
  success
  failed
  skipped_locked
}

/// Fulfillment ecommerce (stub M1 — sin lógica aún)
enum TnFulfillmentStatus {
  pending
  processing
  shipped
  delivered
  cancelled
}

/// Origen del remito ERP — no ecommerce obligatorio
enum ErpOrderSource {
  legacy_gas_import
  manual
  wholesale
  showroom
  internal
}

/// Tipo de movimiento stock ledger M4.5
enum StockMovementType {
  sale
  return
  manual_adjustment
}

/// Dirección ledger M4.5
enum StockMovementDirection {
  out
  in
  adjust
}

/// Origen de un Financial Item — M6.1
enum FinancialItemOriginType {
  TN_ORDER
  REMITO
}

// ─── A) Fuente Tiendanube (universo ventas / facturación KPI) ───────────────

/// Orden ecommerce TN — entidad principal ventas/facturación (M1 TN-first)
model TnOrder {
  id                  String    @id // tn_order_id
  channel             TnOrderChannel @default(ecommerce) @map("channel")
  commercialStatus    TnCommercialStatus? @map("commercial_status")
  commercialStatusAt  DateTime? @map("commercial_status_at")

  tnCreatedAt         DateTime? @map("tn_created_at")
  tnPaidAt            DateTime? @map("tn_paid_at")
  tnStatus            String?   @map("tn_status")
  tnPaymentStatus     String?   @map("tn_payment_status")
  tnTotal             Decimal   @default(0) @map("tn_total") @db.Decimal(14, 2)
  tnSubtotal          Decimal?  @map("tn_subtotal") @db.Decimal(14, 2)
  tnShipping          Decimal?  @map("tn_shipping") @db.Decimal(14, 2)
  tnDiscount          Decimal?  @map("tn_discount") @db.Decimal(14, 2)
  /// Panel TN / analytics la incluye en ventas del período
  tnAnalyticsCounted  Boolean?  @map("tn_analytics_counted")
  /// Flags: panelExcluded, cancelled, custom, boundaryTz, etc.
  tnReportingFlags    Json?     @map("tn_reporting_flags")
  rawTnPayload        Json?     @map("raw_tn_payload")

  /// Cliente / envío / pago — denormalizado desde TN API (M1)
  customerName        String?   @map("customer_name")
  customerDni         String?   @map("customer_dni")
  customerPhone       String?   @map("customer_phone")
  provinceLocalidad   String?   @map("province_localidad")
  paymentGateway      String?   @map("payment_gateway")
  paymentMethod       String?   @map("payment_method")
  shippingOption      String?   @map("shipping_option")
  shippingOwner       String?   @map("shipping_owner")

  /// MP cabecera ecommerce (stub M1 — sin match automático aún)
  mpPaymentId         String?   @map("mp_payment_id")
  netoMpOrden         Decimal?  @map("neto_mp_orden") @db.Decimal(14, 2)
  mpFeeTotal          Decimal?  @map("mp_fee_total") @db.Decimal(14, 2)
  mpCostTotal         Decimal?  @map("mp_cost_total") @db.Decimal(14, 2)

  fulfillmentStatus   TnFulfillmentStatus? @map("fulfillment_status")
  allocatedAt         DateTime? @map("allocated_at")
  stockDeductedAt     DateTime? @map("stock_deducted_at")
  /// Último updated_at visto en API TN (watermark M5.1)
  tnUpdatedAt         DateTime? @map("tn_updated_at")

  syncedAt            DateTime  @default(now()) @map("synced_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  items        TnOrderItem[]
  itemUnits    TnOrderItemUnit[]
  allocations  TnOrderItemAllocation[]
  payments     Payment[]
  stockMoves   StockMovement[]
  /// Link opcional 0..1 a remito legacy/manual — no obligatorio ecommerce
  erpOrder     ErpOrder?

  @@index([tnPaidAt])
  @@index([tnPaymentStatus])
  @@index([tnAnalyticsCounted])
  @@index([commercialStatus])
  @@index([channel])
  @@index([mpPaymentId])
  @@index([tnUpdatedAt])
  @@map("tn_orders")
}

/// Línea de producto desde API Tiendanube (sin prorrateo ERP)
model TnOrderItem {
  id           String   @id @default(cuid())
  tnOrderId    String   @map("tn_order_id")
  tnLineId     String?  @map("tn_line_id")
  sku          String?
  productName  String?  @map("product_name")
  variantName  String?  @map("variant_name")
  quantity     Int      @default(1)
  unitPrice    Decimal  @default(0) @map("unit_price") @db.Decimal(14, 2)
  lineTotal    Decimal  @default(0) @map("line_total") @db.Decimal(14, 2)
  rawLine      Json?    @map("raw_line")
  /// Owner 8Q/SCNL — stub M1 (poblado en M4 allocations)
  owner        String?

  tnOrder     TnOrder                  @relation(fields: [tnOrderId], references: [id], onDelete: Cascade)
  units       TnOrderItemUnit[]
  allocations TnOrderItemAllocation[]
  stockMoves  StockMovement[]

  @@index([tnOrderId])
  @@index([sku])
  @@map("tn_order_items")
}

/// Unidad física (1 prenda = 1 fila) — grain operativo M4 / paridad GAS REMITO_ITEMS
model TnOrderItemUnit {
  id            String   @id @default(cuid())
  tnOrderId     String   @map("tn_order_id")
  tnOrderItemId String   @map("tn_order_item_id")
  /// Índice 0..quantity-1 dentro de la línea TN
  unitIndex     Int      @map("unit_index")
  sku           String?
  talle         String?
  /// Owner inferido del SKU (8Q | SCNL) — M4.4 puede refinar desde STOCK MAESTRO
  owner         String?
  unitPrice     Decimal  @default(0) @map("unit_price") @db.Decimal(14, 2)
  isGifty       Boolean  @default(false) @map("is_gifty")
  /// false para GIFTY u otros no deducibles de STOCK MAESTRO
  isStockable   Boolean  @default(true) @map("is_stockable")
  parseWarnings Json?    @map("parse_warnings")
  source        String   @default("m4_unit_expand")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tnOrder     TnOrder                @relation(fields: [tnOrderId], references: [id], onDelete: Cascade)
  tnOrderItem TnOrderItem            @relation(fields: [tnOrderItemId], references: [id], onDelete: Cascade)
  allocation  TnOrderItemAllocation?
  stockMoves  StockMovement[]

  @@unique([tnOrderItemId, unitIndex])
  @@index([tnOrderId])
  @@index([sku])
  @@index([isStockable])
  @@map("tn_order_item_units")
}

/// Prorrateo comercial por unidad TN — M4.2 (grain = tn_order_item_units)
model TnOrderItemAllocation {
  id                        String   @id @default(cuid())
  tnOrderId                 String   @map("tn_order_id")
  /// Denorm — línea TN origen
  tnOrderItemId             String   @map("tn_order_item_id")
  tnOrderItemUnitId         String   @unique @map("tn_order_item_unit_id")
  /// Denorm — precio bruto unitario (gross_unit_amount)
  grossUnitAmount           Decimal  @default(0) @map("gross_unit_amount") @db.Decimal(14, 2)
  discountAllocated         Decimal  @default(0) @map("discount_allocated") @db.Decimal(14, 2)
  shippingAllocated         Decimal  @default(0) @map("shipping_allocated") @db.Decimal(14, 2)
  feeAllocated              Decimal  @default(0) @map("fee_allocated") @db.Decimal(14, 2)
  /// net_commercial_amount (neto prenda comercial TN)
  netoPrenda                Decimal  @default(0) @map("neto_prenda") @db.Decimal(14, 2)
  netoPrendaReal            Decimal?  @map("neto_prenda_real") @db.Decimal(14, 2)
  mpTaxAllocatedReal        Decimal?  @map("mp_tax_allocated_real") @db.Decimal(14, 2)
  mpFinancingAllocatedReal  Decimal?  @map("mp_financing_allocated_real") @db.Decimal(14, 2)
  mpFeeAllocatedReal        Decimal?  @map("mp_fee_allocated_real") @db.Decimal(14, 2)
  mpPlatformFeeAllocatedReal Decimal? @map("mp_platform_fee_allocated_real") @db.Decimal(14, 2)
  mpTotalCostAllocatedReal  Decimal?  @map("mp_total_cost_allocated_real") @db.Decimal(14, 2)
  owner                     String?
  netoPrendaScnl            Decimal?  @map("neto_prenda_scnl") @db.Decimal(14, 2)
  netoPrenda8q              Decimal?  @map("neto_prenda_8q") @db.Decimal(14, 2)
  source                    String   @default("m4_commercial_allocation")
  createdAt                 DateTime @default(now()) @map("created_at")
  updatedAt                 DateTime @updatedAt @map("updated_at")

  tnOrder         TnOrder         @relation(fields: [tnOrderId], references: [id], onDelete: Cascade)
  tnOrderItem     TnOrderItem     @relation(fields: [tnOrderItemId], references: [id], onDelete: Cascade)
  tnOrderItemUnit TnOrderItemUnit @relation(fields: [tnOrderItemUnitId], references: [id], onDelete: Cascade)

  @@index([tnOrderId])
  @@index([tnOrderItemId])
  @@map("tn_order_item_allocations")
}

// ─── B) Procesamiento ERP (remito, netos, MP, owner, stock) ────────────────

model Customer {
  id                 String   @id @default(cuid())
  externalKey        String   @unique @map("external_key")
  nombre             String
  dni                String?
  provinciaLocalidad String?  @map("provincia_localidad")
  telefono           String?
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  erpOrders ErpOrder[]

  @@map("customers")
}

/// Remito ERP — manual / mayorista / showroom / interno / legacy GAS (no obligatorio ecommerce)
model ErpOrder {
  id                   String                    @id // ID Remito ej. R-1780…
  orderSource          ErpOrderSource            @default(legacy_gas_import) @map("order_source")
  tnOrderId            String?                   @unique @map("tn_order_id")
  customerId           String?                   @map("customer_id")
  fechaErp             DateTime                  @map("fecha_erp")
  processingStatus     ErpProcessingStatus       @default(pending_import) @map("processing_status")
  reconciliationStatus TnErpReconciliationStatus @default(unknown) @map("reconciliation_status")
  reconciliationNote   String?                   @map("reconciliation_note")

  nombre               String
  dni                  String?
  provinciaLocalidad   String?  @map("provincia_localidad")
  telefono             String?
  transporte           String?
  metodoPago           String?  @map("metodo_pago")
  vendedor             String?
  condicionCompra      String?  @map("condicion_compra")
  estado               String?
  totalPrendas         Int      @default(0) @map("total_prendas")

  /// Montos ERP (post-import / allocation — distintos de tn_total para reporting)
  subtotalErp          Decimal  @default(0) @map("subtotal_erp") @db.Decimal(14, 2)
  shippingCustomerCost Decimal  @default(0) @map("shipping_customer_cost") @db.Decimal(14, 2)
  envioOwner           String?  @map("envio_owner")
  shippingOwnerCost    Decimal  @default(0) @map("shipping_owner_cost") @db.Decimal(14, 2)
  recargoDescuento     Decimal  @default(0) @map("recargo_descuento") @db.Decimal(14, 2)
  totalFinalErp        Decimal  @default(0) @map("total_final_erp") @db.Decimal(14, 2)
  netoOperativo        Decimal? @map("neto_operativo") @db.Decimal(14, 2)

  detalleGeneral       String?  @map("detalle_general")
  scnlItems            String?  @map("scnl_items")
  duenoScnlMonto       Decimal? @map("dueno_scnl_monto") @db.Decimal(14, 2)

  source               String   @default("gas_backfill")
  sheetRowHash         String?  @map("sheet_row_hash")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  customer    Customer?      @relation(fields: [customerId], references: [id], onDelete: SetNull)
  tnOrder     TnOrder?       @relation(fields: [tnOrderId], references: [id], onDelete: SetNull)
  items       ErpOrderItem[]
  payments    Payment[]
  importLogs  ImportLog[]
  stockMoves  StockMovement[]

  @@index([fechaErp])
  @@index([estado])
  @@index([processingStatus])
  @@index([reconciliationStatus])
  @@index([orderSource])
  @@map("erp_orders")
}

/// Línea REMITO_ITEMS — prorrateo, netos, owner 8Q/SCNL
model ErpOrderItem {
  id                        String    @id @default(cuid())
  erpOrderId                String    @map("erp_order_id")
  tnOrderItemId             String?   @map("tn_order_item_id")
  fechaErp                  DateTime? @map("fecha_erp")
  sku                       String
  articulo                  String?
  talle                     String?
  cantidad                  Int       @default(1)
  precioUnitario            Decimal   @default(0) @map("precio_unitario") @db.Decimal(14, 2)
  owner                     String?
  metodoPago                String?   @map("metodo_pago")
  descuentoAsignado         Decimal   @default(0) @map("descuento_asignado") @db.Decimal(14, 2)
  shippingAsignado          Decimal   @default(0) @map("shipping_asignado") @db.Decimal(14, 2)
  feeAsignado               Decimal   @default(0) @map("fee_asignado") @db.Decimal(14, 2)
  netoPrenda                Decimal   @default(0) @map("neto_prenda") @db.Decimal(14, 2)
  netoPrendaReal            Decimal?  @map("neto_prenda_real") @db.Decimal(14, 2)
  mpFeeAsignadoReal         Decimal?  @map("mp_fee_asignado_real") @db.Decimal(14, 2)
  mpPlatformFeeAsignadoReal Decimal?  @map("mp_platform_fee_asignado_real") @db.Decimal(14, 2)
  mpTotalCostAsignadoReal   Decimal?  @map("mp_total_cost_asignado_real") @db.Decimal(14, 2)
  netoPrendaScnl            Decimal?  @map("neto_prenda_scnl") @db.Decimal(14, 2)
  netoPrenda8q              Decimal?  @map("neto_prenda_8q") @db.Decimal(14, 2)
  source                    String    @default("gas_backfill")
  createdAt                 DateTime  @default(now()) @map("created_at")
  updatedAt                 DateTime  @updatedAt @map("updated_at")

  erpOrder   ErpOrder        @relation(fields: [erpOrderId], references: [id], onDelete: Cascade)
  stockMoves StockMovement[]

  @@index([erpOrderId])
  @@index([sku])
  @@index([fechaErp])
  @@map("erp_order_items")
}

/// Movimiento de stock — ledger append-only TN-first (M4.5)
model StockMovement {
  id                String                 @id @default(cuid())
  tnOrderId         String?                @map("tn_order_id")
  tnOrderItemId     String?                @map("tn_order_item_id")
  tnOrderItemUnitId String?                @map("tn_order_item_unit_id")
  erpOrderId        String?                @map("erp_order_id")
  erpOrderItemId    String?                @map("erp_order_item_id")
  sku               String
  talle             String?
  owner             String?
  quantity          Int
  movementType      StockMovementType      @map("movement_type")
  direction         StockMovementDirection
  reason            String?
  idempotencyKey    String                 @unique @map("idempotency_key")
  correlationId     String?                @map("correlation_id")
  source            String                 @default("m4_stock_ledger")
  createdAt         DateTime               @default(now()) @map("created_at")

  tnOrder         TnOrder?         @relation(fields: [tnOrderId], references: [id], onDelete: Cascade)
  tnOrderItem     TnOrderItem?     @relation(fields: [tnOrderItemId], references: [id], onDelete: SetNull)
  tnOrderItemUnit TnOrderItemUnit? @relation(fields: [tnOrderItemUnitId], references: [id], onDelete: SetNull)
  erpOrder        ErpOrder?        @relation(fields: [erpOrderId], references: [id], onDelete: Cascade)
  erpOrderItem    ErpOrderItem?    @relation(fields: [erpOrderItemId], references: [id], onDelete: SetNull)

  @@unique([tnOrderItemUnitId, movementType])
  @@index([tnOrderId])
  @@index([tnOrderItemUnitId])
  @@index([erpOrderId])
  @@index([sku])
  @@index([movementType])
  @@index([correlationId])
  @@map("stock_movements")
}

/// Cabecera bootstrap inventario — punto cero ERP V2 (M4.8)
model InventorySnapshotRun {
  id             String   @id @default(cuid())
  snapshotDate   DateTime @map("snapshot_date")
  label          String
  source         String   @default("stock_maestro_bootstrap")
  rowCount       Int      @default(0) @map("row_count")
  isActive       Boolean  @default(false) @map("is_active")
  importedAt     DateTime @default(now()) @map("imported_at")
  importedBy     String?  @map("imported_by")
  checksumSha256 String?  @map("checksum_sha256")
  notes          String?

  lines InventorySnapshotLine[]

  @@unique([snapshotDate, source])
  @@map("inventory_snapshot_runs")
}

/// Línea snapshot — grain SKU + talle + owner (M4.8)
model InventorySnapshotLine {
  id           String   @id @default(cuid())
  runId        String   @map("run_id")
  snapshotDate DateTime @map("snapshot_date")
  sku          String
  talle        String
  owner        String   @default("8Q")
  quantity     Int
  source       String   @default("stock_maestro_bootstrap")
  createdAt    DateTime @default(now()) @map("created_at")

  run InventorySnapshotRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@unique([runId, sku, talle, owner])
  @@index([sku, talle])
  @@index([snapshotDate])
  @@map("inventory_snapshot_lines")
}

// ─── Trazas e integraciones ──────────────────────────────────────────────────

model ImportLog {
  id            String   @id @default(cuid())
  correlationId String?  @map("correlation_id")
  tnOrderId     String?  @map("tn_order_id")
  phase         String
  status        String
  reason        String?
  dryRun        Boolean  @default(true) @map("dry_run")
  elapsedMs     Int?     @map("elapsed_ms")
  erpOrderId    String?  @map("erp_order_id")
  payload       Json?
  createdAt     DateTime @default(now()) @map("created_at")

  erpOrder ErpOrder? @relation(fields: [erpOrderId], references: [id], onDelete: SetNull)

  @@index([tnOrderId])
  @@index([status])
  @@index([correlationId])
  @@map("import_logs")
}

/// Pago Mercado Pago — polimórfico: tn_order (ecommerce) o erp_order (manual)
model Payment {
  id                     String    @id @default(cuid())
  tnOrderId              String?   @map("tn_order_id")
  erpOrderId             String?   @map("erp_order_id")
  mpPaymentId            String?   @unique @map("mp_payment_id")
  mpAdditionalReference  String?   @map("mp_additional_reference")
  mpMatchConfidence      String?   @map("mp_match_confidence")
  mpMatchRule            String?   @map("mp_match_rule")
  mpMatchedAt            DateTime? @map("mp_matched_at")
  mpImportedAt           DateTime? @map("mp_imported_at")
  mpStatus               String?   @map("mp_status")
  mpStatusDetail         String?   @map("mp_status_detail")
  mpDateCreated          DateTime? @map("mp_date_created")
  mpDateApproved         DateTime? @map("mp_date_approved")
  mpMoneyReleaseDate     DateTime? @map("mp_money_release_date")
  mpAcreditadoFecha      DateTime? @map("mp_acreditado_fecha")
  mpTransactionAmount    Decimal?  @map("mp_transaction_amount") @db.Decimal(14, 2)
  mpNetReceivedAmount    Decimal?  @map("mp_net_received_amount") @db.Decimal(14, 2)
  mpNetoRealOrden        Decimal?  @map("mp_neto_real_orden") @db.Decimal(14, 2)
  mpTaxTotalReal         Decimal?  @map("mp_tax_total_real") @db.Decimal(14, 2)
  mpFinancingTotalReal   Decimal?  @map("mp_financing_total_real") @db.Decimal(14, 2)
  mpFeeTotalReal         Decimal?  @map("mp_fee_total_real") @db.Decimal(14, 2)
  mpPlatformFeeTotalReal Decimal?  @map("mp_platform_fee_total_real") @db.Decimal(14, 2)
  mpTotalCostReal        Decimal?  @map("mp_total_cost_real") @db.Decimal(14, 2)
  mpPayerEmail           String?   @map("mp_payer_email")
  mpPaymentType          String?   @map("mp_payment_type")
  mpPaymentMethod        String?   @map("mp_payment_method")
  mpInstallments         Int?      @map("mp_installments")
  source                 String    @default("gas_backfill")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  tnOrder  TnOrder?  @relation(fields: [tnOrderId], references: [id], onDelete: Cascade)
  erpOrder ErpOrder? @relation(fields: [erpOrderId], references: [id], onDelete: Cascade)

  @@index([tnOrderId])
  @@index([erpOrderId])
  @@index([mpStatus])
  @@map("payments")
}

/// Cursor incremental M5.1 — watermark por scope (TN live import)
model SyncState {
  scope         String    @id
  watermarkAt   DateTime  @map("watermark_at")
  lastRunAt     DateTime? @map("last_run_at")
  lastRunMode   String?   @map("last_run_mode")
  lastRunStats  Json?     @map("last_run_stats")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@map("sync_state")
}

/// Historial de corridas del pipeline live M5.4 (scheduler + monitoring)
model PipelineRun {
  id                           String            @id @default(cuid())
  startedAt                    DateTime          @map("started_at")
  finishedAt                   DateTime?         @map("finished_at")
  durationMs                   Int?              @map("duration_ms")
  status                       PipelineRunStatus
  ordersImported               Int               @default(0) @map("orders_imported")
  unitsCreated                 Int               @default(0) @map("units_created")
  commercialAllocationsCreated Int               @default(0) @map("commercial_allocations_created")
  mpAllocationsCreated         Int               @default(0) @map("mp_allocations_created")
  stockMovementsCreated        Int               @default(0) @map("stock_movements_created")
  warningsCount                Int               @default(0) @map("warnings_count")
  errorsCount                  Int               @default(0) @map("errors_count")
  pipelineVersion              String            @map("pipeline_version")
  reportJson                   Json?             @map("report_json")
  failedStage                  String?           @map("failed_stage")
  triggeredBy                  String            @default("scheduler") @map("triggered_by")
  correlationId                String?           @map("correlation_id")
  alertEmailSent               Boolean           @default(false) @map("alert_email_sent")
  createdAt                    DateTime          @default(now()) @map("created_at")

  @@index([startedAt])
  @@index([status])
  @@map("pipeline_runs")
}

// ─── M6 — Financial Items (fuente financiera unificada) ───────────────────────

/// Unidad financiera — 1 prenda vendida = 1 fila (M6.1 TN generator)
model FinancialItem {
  id                 String                  @id @default(cuid())
  originType         FinancialItemOriginType @map("origin_type")
  originId           String                  @map("origin_id")
  originItemId       String                  @map("origin_item_id")
  unitKey            String                  @map("unit_key")

  date               DateTime                @map("date")
  customerName       String?                 @map("customer_name")
  sku                String
  productName        String                  @map("product_name")
  variantName        String?                 @map("variant_name")
  quantity           Int                     @default(1)

  grossAmount        Decimal                 @default(0) @map("gross_amount") @db.Decimal(14, 2)
  discountAllocated  Decimal                 @default(0) @map("discount_allocated") @db.Decimal(14, 2)
  tnFeeAllocated     Decimal                 @default(0) @map("tn_fee_allocated") @db.Decimal(14, 2)
  mpFeeAllocated     Decimal                 @default(0) @map("mp_fee_allocated") @db.Decimal(14, 2)
  shippingAllocated  Decimal                 @default(0) @map("shipping_allocated") @db.Decimal(14, 2)
  metaAdsAllocated   Decimal?                @map("meta_ads_allocated") @db.Decimal(14, 2)

  netAmount          Decimal                 @default(0) @map("net_amount") @db.Decimal(14, 2)

  paymentMethod      String?                 @map("payment_method")
  status             String
  sourceCreatedAt    DateTime?               @map("source_created_at")

  generatorVersion   String                  @default("m6.1-tn-v1") @map("generator_version")
  createdAt          DateTime                @default(now()) @map("created_at")
  updatedAt          DateTime                @updatedAt @map("updated_at")

  @@unique([originType, unitKey])
  @@index([date])
  @@index([sku])
  @@index([status])
  @@index([originId])
  @@map("financial_items")
}
